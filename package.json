{
  "name": "offline-dms",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --webpack -H 127.0.0.1",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "migrate": "tsx scripts/migrate.ts",
    "db:init": "npm run migrate",
    "electron:dev": "node scripts/stop-app-processes.js && cross-env NODE_ENV=development electron .",
    "electron:pack": "node scripts/stop-app-processes.js && npm run build && node scripts/prepare-standalone.js && electron-builder --win --dir",
    "electron:build": "node scripts/stop-app-processes.js && npm run build && node scripts/prepare-standalone.js && electron-builder --win"
  },
  "build": {
    "appId": "com.offlinedms.faced",
    "productName": "Offline DMS",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "config.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron-standalone",
        "to": "standalone"
      }
    ],
    "afterPack": "scripts/after-pack.js",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@libsql/client": "^0.17.4",
    "dexie": "^4.4.4",
    "html2pdf.js": "^0.14.0",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^25.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-qr-code": "^2.2.0",
    "uuid": "^14.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  }
}
