# Turso (libSQL) — https://turso.tech
# Create a database: turso db create offline-dms
# Get URL:        turso db show offline-dms --url
# Create token:   turso db tokens create offline-dms

# Remote Turso (optional — comment out to use local SQLite instead)
# TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# Local SQLite when Turso is not configured (default: face_db.db)
# SQLITE_DATABASE_PATH=face_db.db

# Optional: protect sync API in production
# SYNC_API_SECRET=generate-a-random-secret

# Password for /verify duplicate-check page (default: verify123)
# VERIFY_PASSWORD=verify123

# Admin panel password
# ADMIN_PASSWORD=your-admin-password

# Run migrations after setting credentials:
# npm run migrate
